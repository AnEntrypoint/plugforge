{
  "$schema": "https://schemas.modelcontextprotocol.io/0.1.0/mcp.json",
  "mcpServers": {
    "code_execution": {
      "command": "npx",
      "args": ["-y", "mcp-gm"],
      "timeout": 360000
    },
    "code-search": {
      "command": "bun x",
      "args": [
        "codebasesearch@latest"
      ],
      "timeout": 360000
    }
  }
}