{
  "schemaVersion": 1,
  "description": "Hook spec for gm Gemini CLI extension",
  "envVar": "extensionPath",
  "events": [
    {
      "eventKey": "BeforeTool",
      "commands": [
        {
          "kind": "plugkit",
          "subcommand": "pre-tool-use",
          "timeout": 3600
        }
      ]
    },
    {
      "eventKey": "SessionStart",
      "commands": [
        {
          "kind": "plugkit",
          "subcommand": "session-start",
          "timeout": 180000
        }
      ]
    },
    {
      "eventKey": "BeforeAgent",
      "commands": [
        {
          "kind": "plugkit",
          "subcommand": "prompt-submit",
          "timeout": 60000
        }
      ]
    },
    {
      "eventKey": "SessionEnd",
      "commands": [
        {
          "kind": "plugkit",
          "subcommand": "stop",
          "timeout": 300000
        },
        {
          "kind": "plugkit",
          "subcommand": "stop-git",
          "timeout": 60000
        }
      ]
    }
  ]
}