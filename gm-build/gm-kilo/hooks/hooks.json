{
  "description": "Hooks for gm Kilo CLI extension",
  "hooks": {
    "tool.execute.before": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${KILO_PLUGIN_ROOT}/bin/plugkit hook pre-tool-use",
            "timeout": 3600
          }
        ]
      }
    ],
    "session.created": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${KILO_PLUGIN_ROOT}/bin/plugkit hook session-start",
            "timeout": 180000
          }
        ]
      }
    ],
    "message.updated": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${KILO_PLUGIN_ROOT}/scripts/bootstrap.js",
            "timeout": 60000
          },
          {
            "type": "command",
            "command": "${KILO_PLUGIN_ROOT}/bin/plugkit hook prompt-submit",
            "timeout": 60000
          }
        ]
      }
    ],
    "session.closing": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${KILO_PLUGIN_ROOT}/bin/plugkit hook stop",
            "timeout": 300000
          },
          {
            "type": "command",
            "command": "${KILO_PLUGIN_ROOT}/bin/plugkit hook stop-git",
            "timeout": 60000
          }
        ]
      }
    ]
  }
}